{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@endfield/domain": ["packages/domain/src/index.ts"],
      "@endfield/data": ["packages/data/src/index.ts"],
      "@endfield/data/node": ["packages/data/src/node.ts"],
      "@endfield/optimizer": ["packages/optimizer/src/index.ts"]
    }
  }
}
